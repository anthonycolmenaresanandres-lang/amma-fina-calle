# Fina Calle OS — Owner Portal environment
# Copy to .env.local for local dev, and set the same values in Vercel project
# settings. Never commit real values. The app runs without these (owner/menu
# routes show a "setup needed" state); they are required to enable the portal.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe for the browser; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: canonical app origin used to build magic-link redirect URLs.
# If unset, the request host is used. Set this in production to your domain,
# e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=
